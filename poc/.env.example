# 环境变量配置
# 复制此文件为 .env 并填入你的 API Key

# ============ 图像生成 ============

# Replicate API Token
# 获取地址: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Fal.ai API Key
# 获取地址: https://fal.ai/dashboard/keys
FAL_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============ 视频生成 ============

# Runway API Key
# 获取地址: https://dev.runwayml.com/ (需要申请)
RUNWAY_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Luma AI API Key
# 获取地址: https://lumalabs.ai/dream-machine/api
LUMA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============ 语音合成 (TTS) ============

# 火山引擎 TTS
# 获取地址: https://console.volcengine.com/speech/service/8
VOLC_APP_ID=xxxxxxxxxxxx
VOLC_ACCESS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ElevenLabs
# 获取地址: https://elevenlabs.io/api
ELEVENLABS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# MiniMax
# 获取地址: https://api.minimax.chat/
MINIMAX_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxx
MINIMAX_GROUP_ID=xxxxxxxxxxxx

# ============ LLM ============

# DeepSeek
# 获取地址: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (备选)
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============ 测试 ============

# 测试用图片URL (可选)
TEST_IMAGE_URL=https://example.com/your-reference-image.jpg
