# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_comic_drama

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-min-32-characters

# Google OAuth (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI Models - LLM
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

OPENAI_API_KEY=your-openai-api-key

# AI Models - Image Generation
REPLICATE_API_TOKEN=your-replicate-api-token
FAL_KEY=your-fal-api-key

# AI Models - Video Generation
RUNWAY_API_KEY=your-runway-api-key
LUMA_API_KEY=your-luma-api-key

# AI Models - Voice Synthesis
VOLC_APP_ID=your-volcengine-app-id
VOLC_ACCESS_TOKEN=your-volcengine-access-token
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Encryption
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# File Storage
# Cloudflare R2 (Optional)
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=ai-comic-drama
R2_PUBLIC_URL=https://your-bucket.r2.dev

# Redis (Optional, for distributed rate limiting)
REDIS_URL=redis://localhost:6379

# Payment (Optional)
# WeChat Pay
WECHAT_APPID=your-wechat-appid
WECHAT_MCHID=your-wechat-merchant-id
WECHAT_API_V3_KEY=your-wechat-api-v3-key
WECHAT_SERIAL_NO=your-certificate-serial-number

# Alipay
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=your-alipay-public-key

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Content Safety (Optional)
ALIBABA_CLOUD_ACCESS_KEY_ID=your-alibaba-access-key
ALIBABA_CLOUD_ACCESS_KEY_SECRET=your-alibaba-secret-key

TENCENT_SECRET_ID=your-tencent-secret-id
TENCENT_SECRET_KEY=your-tencent-secret-key
